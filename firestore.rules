rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Helper to check if user is admin of a family doc
    function isAdmin(famId) {
      return isSignedIn() && request.auth.token.email_verified == true && 
        get(/databases/$(database)/documents/families/$(famId)).data.adminId == request.auth.uid;
    }
    
    // Helper to check if user is a member of the family
    function isMember(famId) {
      return isSignedIn() && request.auth.token.email_verified == true && (
        exists(/databases/$(database)/documents/families/$(famId)/members/$(request.auth.uid)) || 
        get(/databases/$(database)/documents/families/$(famId)).data.adminId == request.auth.uid
      );
    }

    // --- Rules ---

    // User Roles & Metadata
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && 
        incoming().role in ['owner', 'user'];
      allow update: if isSignedIn() && request.auth.uid == userId && 
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email']);
    }

    // Families
    match /families/{familyId} {
      // Allow listing if the user is the admin (for the query in App.tsx)
      allow list: if isSignedIn() && (
        query.limit == 1 || 
        resource.data.adminId == request.auth.uid
      ); 
      allow get: if isMember(familyId);
      allow create: if isSignedIn() && request.auth.token.email_verified == true && incoming().adminId == request.auth.uid;
      allow update: if isAdmin(familyId);
      
      // Members
      match /members/{memberId} {
        allow list: if isMember(familyId); 
        allow get: if isMember(familyId);
        allow create, update: if isAdmin(familyId) || (isSignedIn() && request.auth.uid == memberId);
        allow delete: if isAdmin(familyId);
      }

      // Consents
      match /consents/{memberId} {
        allow list: if isAdmin(familyId); // Admin sees all consents for modeling
        allow get: if isAdmin(familyId) || (isSignedIn() && request.auth.uid == memberId); 
        allow create, update: if isSignedIn() && request.auth.uid == memberId;
      }

      // Health Data
      match /healthData/{dataId} {
        allow list: if isAdmin(familyId) || (isSignedIn() && resource.data.memberId == request.auth.uid);
        allow create: if (isMember(familyId)) && incoming().memberId == request.auth.uid;
        allow update, delete: if isSignedIn() && existing().memberId == request.auth.uid;
        allow get: if isAdmin(familyId) || (isSignedIn() && resource.data.memberId == request.auth.uid);
      }

      // Audit Log
      match /auditLog/{logId} {
        allow list: if isAdmin(familyId);
        allow create: if isMember(familyId);
      }

      // Risk Assessments
      match /assessments/{assessmentId} {
        allow list: if isMember(familyId);
        allow read: if isMember(familyId);
        allow create: if isAdmin(familyId);
      }
    }
  }
}

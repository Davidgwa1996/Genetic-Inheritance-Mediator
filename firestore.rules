rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // 3. Helper Functions
    // ---------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Auth tokens contain email if using Google or Email link
    function isOwner() {
      return isSignedIn() && request.auth.token.email == 'njaudavid5@gmail.com';
    }

    function isUserSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Master Gate (Relational Sync) - Pillar 1
    function getFamily(familyId) {
      return get(/databases/$(database)/documents/families/$(familyId)).data;
    }

    // Note: get() lookups are limited to 10 per request.
    // If a list query triggers this, it might fail for non-admins if not optimized.
    function isFamilyMember(familyId) {
      let familyData = getFamily(familyId);
      return isSignedIn() && (familyData.adminId == request.auth.uid || request.auth.uid in familyData.memberIds);
    }

    // ---------------------------------------------------------
    // 0. Global Safety Net
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // Users Collection
    // ---------------------------------------------------------
    match /users/{userId} {
      allow read: if isOwner() || isUserSelf(userId);
      allow create: if isSignedIn() && isUserSelf(userId);
      allow update: if isOwner() || isUserSelf(userId);
    }

    // ---------------------------------------------------------
    // Benchmarks Collection
    // ---------------------------------------------------------
    match /benchmarks/{benchmarkId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    // ---------------------------------------------------------
    // Families Collection & Subcollections
    // ---------------------------------------------------------
    match /families/{familyId} {
      allow read: if isOwner() || (isSignedIn() && (
        resource.data.adminId == request.auth.uid || 
        request.auth.uid in resource.data.memberIds
      ));
      allow create: if isVerified();
      allow update: if isOwner() || (isSignedIn() && resource.data.adminId == request.auth.uid);
      allow delete: if isOwner();

      // Subcollections
      
      match /members/{memberId} {
        // Pillar 8: Avoid get() in list queries for non-admins if possible.
        // For members collection, we often query by userId.
        allow list: if isOwner() || (isSignedIn() && (resource.data.userId == request.auth.uid || isFamilyMember(familyId)));
        allow get: if isOwner() || isFamilyMember(familyId);
        allow create: if isOwner() || (isVerified() && request.resource.data.userId == request.auth.uid);
        allow update: if isOwner() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }

      match /consents/{consentId} {
        allow read: if isOwner() || isFamilyMember(familyId) || isUserSelf(consentId);
        allow write: if isOwner() || isUserSelf(consentId);
      }

      match /healthData/{dataId} {
        // Secure List Queries (Pillar 8)
        allow list: if isOwner() || (isSignedIn() && (resource.data.uploadedBy == request.auth.uid || resource.data.memberId == request.auth.uid));
        allow get: if isOwner() || isFamilyMember(familyId);
        allow create: if isOwner() || (isVerified() && request.resource.data.uploadedBy == request.auth.uid);
        allow delete: if isOwner();
      }

      match /auditLogs/{logId} {
        allow read: if isOwner() || isFamilyMember(familyId);
        allow create: if isVerified();
      }

      match /assessments/{assessmentId} {
        allow read: if isOwner() || isFamilyMember(familyId);
        allow write: if isOwner();
      }
    }
  }
}
